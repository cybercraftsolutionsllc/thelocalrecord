generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Municipality {
  id                 String              @id @default(cuid())
  slug               String              @unique
  name               String
  state              String
  localityType       String
  shortName          String
  disclaimer         String
  about              String
  correctionsEmail   String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  sources            Source[]
  fetchRuns          FetchRun[]
  sourceItems        SourceItem[]
  diffEvents         DiffEvent[]
  contentEntries     ContentEntry[]
  corrections        Correction[]
  savedPlaces        SavedPlace[]
  watchlists         Watchlist[]
  notificationEvents NotificationEvent[]
  communityCoverage  CommunityCoverage?
  entryGeoEntities   EntryGeoEntity[]
}

model Source {
  id             String       @id @default(cuid())
  municipalityId String
  slug           String
  name           String
  description    String
  url            String
  kind           String
  fetchStrategy  String
  implemented    Boolean      @default(false)
  publicCategory String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  municipality   Municipality @relation(fields: [municipalityId], references: [id], onDelete: Cascade)
  sourceItems    SourceItem[]
  artifacts      Artifact[]

  @@unique([municipalityId, slug])
}

model FetchRun {
  id             String       @id @default(cuid())
  municipalityId String
  status         String
  startedAt      DateTime     @default(now())
  completedAt    DateTime?
  statsJson      String?
  errorMessage   String?
  municipality   Municipality @relation(fields: [municipalityId], references: [id], onDelete: Cascade)
  artifacts      Artifact[]
  diffEvents     DiffEvent[]
}

model SourceItem {
  id                   String         @id @default(cuid())
  municipalityId       String
  sourceId             String
  externalId           String
  title                String
  sourceUrl            String
  sourcePageUrl        String
  normalizedText       String
  publishedAt          DateTime?
  eventDate            DateTime?
  contentHash          String
  metadataJson         String
  extractionMethod     String
  extractionConfidence Float
  extractionNote       String?
  firstSeenAt          DateTime       @default(now())
  lastSeenAt           DateTime       @default(now())
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  municipality         Municipality   @relation(fields: [municipalityId], references: [id], onDelete: Cascade)
  source               Source         @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  artifacts            Artifact[]
  diffEvents           DiffEvent[]
  contentEntries       ContentEntry[]

  @@unique([sourceId, externalId])
}

model Artifact {
  id           String      @id @default(cuid())
  sourceId     String?
  sourceItemId String?
  fetchRunId   String?
  kind         String
  url          String
  sha256       String
  mimeType     String?
  createdAt    DateTime    @default(now())
  source       Source?     @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  sourceItem   SourceItem? @relation(fields: [sourceItemId], references: [id], onDelete: Cascade)
  fetchRun     FetchRun?   @relation(fields: [fetchRunId], references: [id], onDelete: Cascade)
}

model DiffEvent {
  id             String        @id @default(cuid())
  municipalityId String
  fetchRunId     String
  sourceItemId   String
  eventType      String
  previousHash   String?
  currentHash    String
  title          String
  classification String
  riskLevel      String
  reviewState    String
  rationaleJson  String
  createdAt      DateTime      @default(now())
  municipality   Municipality  @relation(fields: [municipalityId], references: [id], onDelete: Cascade)
  fetchRun       FetchRun      @relation(fields: [fetchRunId], references: [id], onDelete: Cascade)
  sourceItem     SourceItem    @relation(fields: [sourceItemId], references: [id], onDelete: Cascade)
  contentEntry   ContentEntry?
}

model ContentEntry {
  id                 String              @id @default(cuid())
  municipalityId     String
  sourceItemId       String
  diffEventId        String              @unique
  title              String
  summary            String
  category           String
  impactLevel        String              @default("routine")
  riskLevel          String
  reviewState        String
  sourceLinksJson    String
  extractionNote     String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  municipality       Municipality        @relation(fields: [municipalityId], references: [id], onDelete: Cascade)
  sourceItem         SourceItem          @relation(fields: [sourceItemId], references: [id], onDelete: Cascade)
  diffEvent          DiffEvent           @relation(fields: [diffEventId], references: [id], onDelete: Cascade)
  publication        Publication?
  corrections        Correction[]
  notificationEvents NotificationEvent[]
  geoEntities        EntryGeoEntity[]
}

model Publication {
  id             String       @id @default(cuid())
  contentEntryId String       @unique
  path           String
  status         String
  publishedAt    DateTime     @default(now())
  contentEntry   ContentEntry @relation(fields: [contentEntryId], references: [id], onDelete: Cascade)
}

model Correction {
  id             String        @id @default(cuid())
  municipalityId String
  contentEntryId String?
  reporterName   String?
  reporterEmail  String?
  details        String
  status         String        @default("open")
  createdAt      DateTime      @default(now())
  municipality   Municipality  @relation(fields: [municipalityId], references: [id], onDelete: Cascade)
  contentEntry   ContentEntry? @relation(fields: [contentEntryId], references: [id], onDelete: SetNull)
}

model UserProfile {
  id                     String                  @id @default(cuid())
  providerUid            String                  @unique
  email                  String
  displayName            String?
  authProvider           String
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  lastSeenAt             DateTime?
  savedPlaces            SavedPlace[]
  watchlists             Watchlist[]
  notificationPreference NotificationPreference?
  pushTokens             PushToken[]
  notificationEvents     NotificationEvent[]
}

model SavedPlace {
  id                String       @id @default(cuid())
  userId            String
  label             String
  rawAddress        String
  normalizedAddress String
  zip               String?
  municipalityId    String
  lat               Float?
  lng               Float?
  geocodeConfidence Float?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  deletedAt         DateTime?
  user              UserProfile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  municipality      Municipality @relation(fields: [municipalityId], references: [id], onDelete: Cascade)
  watchlists        Watchlist[]

  @@index([userId])
  @@index([municipalityId])
  @@index([deletedAt])
}

model Watchlist {
  id                 String              @id @default(cuid())
  userId             String
  savedPlaceId       String?
  municipalityId     String
  label              String
  query              String
  topic              String?
  status             String              @default("active")
  notificationLevel  String              @default("important")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?
  user               UserProfile         @relation(fields: [userId], references: [id], onDelete: Cascade)
  savedPlace         SavedPlace?         @relation(fields: [savedPlaceId], references: [id], onDelete: SetNull)
  municipality       Municipality        @relation(fields: [municipalityId], references: [id], onDelete: Cascade)
  notificationEvents NotificationEvent[]

  @@index([userId])
  @@index([municipalityId, status])
  @@index([deletedAt])
}

model NotificationPreference {
  userId                String      @id
  emailEnabled          Boolean     @default(true)
  pushEnabled           Boolean     @default(false)
  digestFrequency       String      @default("as_needed")
  quietHoursStart       String?
  quietHoursEnd         String?
  criticalSourceEnabled Boolean     @default(true)
  updatedAt             DateTime    @updatedAt
  user                  UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PushToken {
  id          String      @id @default(cuid())
  userId      String
  platform    String
  token       String
  deviceLabel String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  revokedAt   DateTime?
  user        UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, token])
  @@index([userId])
  @@index([revokedAt])
}

model NotificationEvent {
  id             String        @id @default(cuid())
  userId         String
  watchlistId    String?
  municipalityId String
  contentEntryId String?
  eventKind      String
  title          String
  body           String
  status         String        @default("observed")
  createdAt      DateTime      @default(now())
  deliveredAt    DateTime?
  readAt         DateTime?
  user           UserProfile   @relation(fields: [userId], references: [id], onDelete: Cascade)
  watchlist      Watchlist?    @relation(fields: [watchlistId], references: [id], onDelete: SetNull)
  municipality   Municipality  @relation(fields: [municipalityId], references: [id], onDelete: Cascade)
  contentEntry   ContentEntry? @relation(fields: [contentEntryId], references: [id], onDelete: SetNull)

  @@unique([userId, watchlistId, contentEntryId, eventKind])
  @@index([userId])
  @@index([municipalityId])
}

model CommunityCoverage {
  municipalityId String       @id
  status         String
  coverageLevel  String
  coverageNotes  String
  lastIngestedAt DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  municipality   Municipality @relation(fields: [municipalityId], references: [id], onDelete: Cascade)
}

model EntryGeoEntity {
  id              String       @id @default(cuid())
  contentEntryId  String
  municipalityId  String
  entityKind      String
  label           String
  normalizedValue String
  lat             Float?
  lng             Float?
  confidence      Float
  createdAt       DateTime     @default(now())
  contentEntry    ContentEntry @relation(fields: [contentEntryId], references: [id], onDelete: Cascade)
  municipality    Municipality @relation(fields: [municipalityId], references: [id], onDelete: Cascade)

  @@index([contentEntryId])
  @@index([municipalityId, normalizedValue])
}
