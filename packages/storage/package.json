{
  "name": "@thelocalrecord/storage",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
