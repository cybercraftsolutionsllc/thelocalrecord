    "seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "@thelocalrecord/core": "workspace:*"
  },
  "devDependencies": {
    "prisma": "^6.6.0"
  }
}
