{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "allowJs": false,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@thelocalrecord/core": ["packages/core/src/index.ts"],
      "@thelocalrecord/content": ["packages/content/src/index.ts"],
      "@thelocalrecord/ingest": ["packages/ingest/src/index.ts"],
      "@thelocalrecord/ingest/adapters": ["packages/ingest/src/adapters.ts"],
      "@thelocalrecord/ingest/detail-enrichment": ["packages/ingest/src/detail-enrichment.ts"],
      "@thelocalrecord/storage": ["packages/storage/src/index.ts"]
    }
  }
}
